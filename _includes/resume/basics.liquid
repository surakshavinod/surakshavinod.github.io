<table class="table table-cv table-sm table-borderless table-responsive table-cv-map">

  <!-- FIRST ROW: EMAIL / LINKEDIN / GITHUB / WEBSITE -->
  <tr>
    <td class="p-1 pr-2 font-weight-bold">
      &nbsp;
    </td>
    <td class="p-1 pl-2 font-weight-light text">
      <a href="mailto:{{ site.data.resume.basics.email }}">Email</a>
      || <a href="https://www.linkedin.com/in/surakshavinod/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      || <a href="https://www.github.com/surakshavinod/" target="_blank" rel="noopener noreferrer">GitHub</a>
      || <a href="https://surakshavinod.github.io/" target="_blank" rel="noopener noreferrer">Website</a>
    </td>
  </tr>

  {% assign skip_basics = 'email,image,location,profiles' | split: ',' %}
  {% for content in data[1] %}
    {% if (content[1] == "") or (skip_basics contains content[0]) %}
      {% continue %}
    {% endif %}

    <tr>
      <td class="p-1 pr-2 font-weight-bold">
        <b>{{ content[0] | capitalize }}</b>
      </td>
      <td class="p-1 pl-2 font-weight-light text">
        {% if content[0] == 'url' %}
          <a href="{{ content[1] }}" target="_blank" rel="noopener noreferrer">{{ content[1] }}</a>
        {% elsif content[0] == 'email' %}
          <a href="mailto:{{ content[1] }}" target="_blank">{{ content[1] }}</a>
        {% elsif content[0] == 'phone' %}
          <a href="tel:{{ content[1] }}">{{ content[1] }}</a>
        {% else %}
          {{ content[1] }}
        {% endif %}
      </td>
    </tr>
  {% endfor %}
</table>
